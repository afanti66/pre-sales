{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["task_id", "phase", "level", "assignee", "status", "created_at"],
  "properties": {
    "task_id": {"type": "string", "pattern": "^(research|framework|design|ppt)-\\d{3}-[a-z-]+$"},
    "phase": {"type": "string", "enum": ["research", "framework", "design", "ppt"]},
    "level": {"type": "string", "enum": ["phase", "stage", "task", "subtask"]},
    "assignee": {"type": "string", "enum": ["vm1", "vm2", "vm3"]},
    "status": {"type": "string", "enum": ["pending", "running", "completed", "failed", "rework"]},
    "depends_on": {"type": "array", "items": {"type": "string"}},
    "input_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {"type": "string", "enum": ["artifact", "template", "knowledge"]},
          "path": {"type": "string"},
          "description": {"type": "string"}
        }
      }
    },
    "output_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": {"type": "string"},
          "description": {"type": "string"}
        }
      }
    },
    "estimated_tokens": {"type": "integer", "minimum": 0},
    "actual_tokens": {"type": "integer", "minimum": 0},
    "created_at": {"type": "string", "format": "date-time"},
    "started_at": {"type": "string", "format": "date-time"},
    "completed_at": {"type": "string", "format": "date-time"},
    "result_summary": {"type": "string"},
    "error": {"type": "string"}
  }
}
