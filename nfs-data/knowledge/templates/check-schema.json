{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["check_id", "phase", "status", "checked_by", "checked_at"],
  "properties": {
    "check_id": {"type": "string"},
    "phase": {"type": "string"},
    "status": {"type": "string", "enum": ["pending", "running", "passed", "failed", "rework"]},
    "checked_by": {"type": "string", "enum": ["vm1", "vm2", "vm3"]},
    "checked_at": {"type": "string"},
    "content_check": {
      "type": "object",
      "properties": {
        "status": {"type": "string", "enum": ["passed", "failed"]},
        "issues": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "severity": {"type": "string", "enum": ["critical", "major", "minor"]},
              "description": {"type": "string"},
              "location": {"type": "string"}
            }
          }
        },
        "completeness": {"type": "number", "minimum": 0, "maximum": 100}
      }
    },
    "proofreading": {
      "type": "object",
      "properties": {
        "status": {"type": "string", "enum": ["passed", "failed"]},
        "issues": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {"type": "string", "enum": ["terminology", "heading_level", "style", "numbering", "figure_ref", "table_ref"]},
              "description": {"type": "string"},
              "suggestion": {"type": "string"}
            }
          }
        }
      }
    },
    "delivery_artifacts": {"type": "array", "items": {"type": "string"}},
    "rework_targets": {"type": "array", "items": {"type": "string"}}
  }
}
